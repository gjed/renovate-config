{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default shareable Renovate config for gjed repositories",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "extends": [
    "config:recommended",
    ":separateMultipleMajorReleases",
    ":timezone(Europe/Rome)",
    "github>gjed/renovate-config:automerge",
    "github>gjed/renovate-config:labels",
    "github>gjed/renovate-config:semanticCommits",
    "github>gjed/renovate-config:vulnerabilityAlerts"
  ]
}
